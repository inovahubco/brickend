{
  "name": "@brickend/supabase",
  "version": "0.0.1",
  "description": "Supabase integration utilities for Brickend framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "check-types": "tsc --noEmit"
  },
  "keywords": [
    "brickend",
    "supabase",
    "database",
    "crud",
    "typescript",
    "code-generation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "@supabase/postgrest-js": "^1.15.8",
    "zod": "^3.23.8",
    "pluralize": "^8.0.0"
  },
  "devDependencies": {
    "@brickend/core": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.18",
    "@types/pluralize": "^0.0.33",
    "eslint": "^9.27.0",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@brickend/core": "workspace:*"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./database": {
      "import": "./dist/database/index.js",
      "types": "./dist/database/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./functions": {
      "import": "./dist/functions/index.js",
      "types": "./dist/functions/index.d.ts"
    }
  }
}
