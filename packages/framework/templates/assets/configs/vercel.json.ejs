{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "<%= names.kebabCase %>",
  "description": "<%= variables.description || 'A Brickend API deployed on Vercel' %>",
  
  "builds": [
    {
      "src": "dist/index.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "<%= variables.lambdaSize || '50mb' %>",
        "runtime": "nodejs<%= variables.nodeVersion || '20' %>.x"
      }
    }
  ],

  "routes": [
    <% if (variables.spa) { %>
    {
      "src": "/(.*)",
      "dest": "/dist/index.js"
    }
    <% } else { %>
    {
      "src": "/health",
      "dest": "/dist/index.js",
      "methods": ["GET"]
    },
    {
      "src": "/health/(.*)",
      "dest": "/dist/index.js",
      "methods": ["GET"]
    },
    {
      "src": "/api",
      "dest": "/dist/index.js",
      "methods": ["GET"]
    },
    <% if (variables.swagger) { %>
    {
      "src": "/docs",
      "dest": "/dist/index.js",
      "methods": ["GET"]
    },
    {
      "src": "/docs/(.*)",
      "dest": "/dist/index.js",
      "methods": ["GET"]
    },
    <% } %>
    <% if (variables.resources && variables.resources.length > 0) { %>
    <% variables.resources.forEach(function(resource) { %>
    {
      "src": "/<%= resource.name %>",
      "dest": "/dist/index.js",
      "methods": ["GET", "POST"]
    },
    {
      "src": "/<%= resource.name %>/(.*)",
      "dest": "/dist/index.js",
      "methods": ["GET", "PUT", "DELETE", "PATCH"]
    },
    <% }); %>
    <% } %>
    {
      "src": "/(.*)",
      "dest": "/dist/index.js"
    }
    <% } %>
  ],

  "env": {
    "NODE_ENV": "production",
    "LOG_LEVEL": "<%= variables.logLevel || 'info' %>",
    <% if (variables.database) { %>
    "DATABASE_URL": "@database-url",
    <% } %>
    <% if (variables.redis) { %>
    "REDIS_URL": "@redis-url",
    <% } %>
    <% if (variables.auth) { %>
    "JWT_SECRET": "@jwt-secret",
    <% } %>
    <% if (variables.customEnvVars) { %>
    <% variables.customEnvVars.forEach(function(envVar) { %>
    "<%= envVar.name %>": "@<%= envVar.name.toLowerCase().replace(/_/g, '-') %>",
    <% }); %>
    <% } %>
    "VERCEL": "1"
  },

  "functions": {
    "dist/index.js": {
      "maxDuration": <%= variables.timeout || 30 %>,
      "memory": <%= variables.memory || 1024 %>,
      "runtime": "nodejs<%= variables.nodeVersion || '20' %>.x"
    }
  },

  <% if (variables.headers || variables.cors || variables.security) { %>
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        <% if (variables.cors) { %>
        {
          "key": "Access-Control-Allow-Origin",
          "value": "<%= variables.corsOrigin || '*' %>"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, X-Requested-With"
        },
        {
          "key": "Access-Control-Max-Age",
          "value": "86400"
        },
        <% } %>
        <% if (variables.security) { %>
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy", 
          "value": "geolocation=(), microphone=(), camera=()"
        },
        <% } %>
        <% if (variables.caching) { %>
        {
          "key": "Cache-Control",
          "value": "public, max-age=<%= variables.cacheMaxAge || '3600' %>"
        },
        <% } %>
        {
          "key": "X-Powered-By",
          "value": "Brickend Framework"
        }
      ]
    }<% if (variables.staticAssets) { %>,
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
    <% } %>
  ],
  <% } %>

  <% if (variables.redirects && variables.redirects.length > 0) { %>
  "redirects": [
    <% variables.redirects.forEach(function(redirect, index) { %>
    {
      "source": "<%= redirect.source %>",
      "destination": "<%= redirect.destination %>",
      "permanent": <%= redirect.permanent || false %>
    }<%= index < variables.redirects.length - 1 ? ',' : '' %>
    <% }); %>
  ],
  <% } %>

  <% if (variables.rewrites && variables.rewrites.length > 0) { %>
  "rewrites": [
    <% variables.rewrites.forEach(function(rewrite, index) { %>
    {
      "source": "<%= rewrite.source %>",
      "destination": "<%= rewrite.destination %>"
    }<%= index < variables.rewrites.length - 1 ? ',' : '' %>
    <% }); %>
  ],
  <% } %>

  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  
  <% if (variables.regions) { %>
  "regions": [<% variables.regions.forEach(function(region, index) { %>"<%= region %>"<%= index < variables.regions.length - 1 ? ', ' : '' %><% }); %>],
  <% } else { %>
  "regions": ["iad1"],
  <% } %>

  <% if (variables.cleanUrls !== false) { %>
  "cleanUrls": true,
  <% } %>
  <% if (variables.trailingSlash === false) { %>
  "trailingSlash": false,
  <% } %>

  "github": {
    "silent": <%= variables.githubSilent || false %>,
    "autoAlias": <%= variables.autoAlias !== false %>
  },

  <% if (variables.crons && variables.crons.length > 0) { %>
  "crons": [
    <% variables.crons.forEach(function(cron, index) { %>
    {
      "path": "<%= cron.path %>",
      "schedule": "<%= cron.schedule %>"
    }<%= index < variables.crons.length - 1 ? ',' : '' %>
    <% }); %>
  ],
  <% } %>

  <% if (variables.edgeConfig) { %>
  "edgeConfig": "<%= variables.edgeConfig %>",
  <% } %>

  <% if (variables.framework) { %>
  "framework": "<%= variables.framework %>",
  <% } %>

  <% if (variables.nodeVersion) { %>
  "engines": {
    "node": "<%= variables.nodeVersion %>"
  },
  <% } %>

  "ignoreCommand": "git diff --quiet HEAD^ HEAD ./"
}