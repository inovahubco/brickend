# Docker Compose configuration for <%= names.pascalCase %>
# Generated by Brickend on <%= now() %>

version: '3.8'

services:
  # Main application service
  app:
    build:
      context: .
      dockerfile: Dockerfile
      target: <% if (variables.environment === 'production') { %>production<% } else { %>development<% } %>
    container_name: <%= names.kebabCase %>-app
    ports:
      - "${PORT:-3000}:3000"
    environment:
      - NODE_ENV=${NODE_ENV:-development}
      - PORT=3000
      - HOST=0.0.0.0
      - LOG_LEVEL=${LOG_LEVEL:-info}
      <% if (variables.database === 'postgresql' || variables.database === 'postgres') { %>
      - DATABASE_URL=postgresql://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-password}@postgres:5432/${POSTGRES_DB:-<%= names.snakeCase %>}
      <% } else if (variables.database === 'mysql') { %>
      - DATABASE_URL=mysql://${MYSQL_USER:-root}:${MYSQL_PASSWORD:-password}@mysql:3306/${MYSQL_DATABASE:-<%= names.snakeCase %>}
      <% } else if (variables.database === 'mongodb') { %>
      - DATABASE_URL=mongodb://${MONGO_USER:-admin}:${MONGO_PASSWORD:-password}@mongodb:27017/${MONGO_DATABASE:-<%= names.snakeCase %>}?authSource=admin
      <% } %>
      <% if (variables.redis) { %>
      - REDIS_URL=redis://redis:6379
      <% } %>
      <% if (variables.customEnvVars) { %>
      <% variables.customEnvVars.forEach(function(envVar) { %>
      - <%= envVar.name %>=${<%= envVar.name %>:-<%= envVar.defaultValue || '' %>}
      <% }); %>
      <% } %>
    volumes:
      <% if (variables.environment !== 'production') { %>
      - ./src:/app/src:ro
      - ./package.json:/app/package.json:ro
      - ./tsconfig.json:/app/tsconfig.json:ro
      <% } %>
      - app_logs:/app/logs
    depends_on:
      <% if (variables.database === 'postgresql' || variables.database === 'postgres') { %>
      - postgres
      <% } else if (variables.database === 'mysql') { %>
      - mysql
      <% } else if (variables.database === 'mongodb') { %>
      - mongodb
      <% } %>
      <% if (variables.redis) { %>
      - redis
      <% } %>
    networks:
      - <%= names.kebabCase %>-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

  <% if (variables.database === 'postgresql' || variables.database === 'postgres') { %>
  # PostgreSQL Database
  postgres:
    image: postgres:16-alpine
    container_name: <%= names.kebabCase %>-postgres
    environment:
      - POSTGRES_DB=${POSTGRES_DB:-<%= names.snakeCase %>}
      - POSTGRES_USER=${POSTGRES_USER:-postgres}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-password}
      - POSTGRES_INITDB_ARGS=--auth-host=scram-sha-256
    ports:
      - "${POSTGRES_PORT:-5432}:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      <% if (variables.initSql) { %>
      - ./docker/postgres/init:/docker-entrypoint-initdb.d:ro
      <% } %>
    networks:
      - <%= names.kebabCase %>-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-postgres} -d ${POSTGRES_DB:-<%= names.snakeCase %>}"]
      interval: 10s
      timeout: 5s
      retries: 5
  <% } %>

  <% if (variables.database === 'mysql') { %>
  # MySQL Database
  mysql:
    image: mysql:8.0
    container_name: <%= names.kebabCase %>-mysql
    environment:
      - MYSQL_DATABASE=${MYSQL_DATABASE:-<%= names.snakeCase %>}
      - MYSQL_USER=${MYSQL_USER:-user}
      - MYSQL_PASSWORD=${MYSQL_PASSWORD:-password}
      - MYSQL_ROOT_PASSWORD=${MYSQL_ROOT_PASSWORD:-rootpassword}
    ports:
      - "${MYSQL_PORT:-3306}:3306"
    volumes:
      - mysql_data:/var/lib/mysql
      <% if (variables.initSql) { %>
      - ./docker/mysql/init:/docker-entrypoint-initdb.d:ro
      <% } %>
    networks:
      - <%= names.kebabCase %>-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-u", "root", "-p${MYSQL_ROOT_PASSWORD:-rootpassword}"]
      interval: 10s
      timeout: 5s
      retries: 5
  <% } %>

  <% if (variables.database === 'mongodb') { %>
  # MongoDB Database
  mongodb:
    image: mongo:7
    container_name: <%= names.kebabCase %>-mongodb
    environment:
      - MONGO_INITDB_ROOT_USERNAME=${MONGO_USER:-admin}
      - MONGO_INITDB_ROOT_PASSWORD=${MONGO_PASSWORD:-password}
      - MONGO_INITDB_DATABASE=${MONGO_DATABASE:-<%= names.snakeCase %>}
    ports:
      - "${MONGO_PORT:-27017}:27017"
    volumes:
      - mongodb_data:/data/db
      <% if (variables.initJs) { %>
      - ./docker/mongodb/init:/docker-entrypoint-initdb.d:ro
      <% } %>
    networks:
      - <%= names.kebabCase %>-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "mongosh", "--eval", "db.adminCommand('ping')"]
      interval: 10s
      timeout: 5s
      retries: 5
  <% } %>

  <% if (variables.redis) { %>
  # Redis Cache
  redis:
    image: redis:7-alpine
    container_name: <%= names.kebabCase %>-redis
    ports:
      - "${REDIS_PORT:-6379}:6379"
    volumes:
      - redis_data:/data
      <% if (variables.redisConfig) { %>
      - ./docker/redis/redis.conf:/usr/local/etc/redis/redis.conf:ro
      <% } %>
    networks:
      - <%= names.kebabCase %>-network
    restart: unless-stopped
    <% if (variables.redisConfig) { %>
    command: redis-server /usr/local/etc/redis/redis.conf
    <% } else { %>
    command: redis-server --appendonly yes --maxmemory 128mb --maxmemory-policy allkeys-lru
    <% } %>
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
  <% } %>

  <% if (variables.nginx) { %>
  # Nginx Reverse Proxy
  nginx:
    image: nginx:alpine
    container_name: <%= names.kebabCase %>-nginx
    ports:
      - "${NGINX_PORT:-80}:80"
      <% if (variables.ssl) { %>
      - "${NGINX_SSL_PORT:-443}:443"
      <% } %>
    volumes:
      - ./docker/nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./docker/nginx/conf.d:/etc/nginx/conf.d:ro
      <% if (variables.ssl) { %>
      - ./docker/nginx/ssl:/etc/nginx/ssl:ro
      <% } %>
      - nginx_logs:/var/log/nginx
    depends_on:
      - app
    networks:
      - <%= names.kebabCase %>-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost/health"]
      interval: 30s
      timeout: 10s
      retries: 3
  <% } %>

  <% if (variables.monitoring) { %>
  # Prometheus Monitoring
  prometheus:
    image: prom/prometheus:latest
    container_name: <%= names.kebabCase %>-prometheus
    ports:
      - "${PROMETHEUS_PORT:-9090}:9090"
    volumes:
      - ./docker/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus_data:/prometheus
    networks:
      - <%= names.kebabCase %>-network
    restart: unless-stopped
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--web.console.libraries=/etc/prometheus/console_libraries'
      - '--web.console.templates=/etc/prometheus/consoles'
      - '--storage.tsdb.retention.time=200h'
      - '--web.enable-lifecycle'

  # Grafana Dashboard
  grafana:
    image: grafana/grafana:latest
    container_name: <%= names.kebabCase %>-grafana
    ports:
      - "${GRAFANA_PORT:-3001}:3000"
    environment:
      - GF_SECURITY_ADMIN_PASSWORD=${GRAFANA_PASSWORD:-admin}
      - GF_USERS_ALLOW_SIGN_UP=false
    volumes:
      - grafana_data:/var/lib/grafana
      - ./docker/grafana/provisioning:/etc/grafana/provisioning:ro
    depends_on:
      - prometheus
    networks:
      - <%= names.kebabCase %>-network
    restart: unless-stopped
  <% } %>

  <% if (variables.mailcatcher) { %>
  # MailCatcher for development
  mailcatcher:
    image: schickling/mailcatcher
    container_name: <%= names.kebabCase %>-mailcatcher
    ports:
      - "${MAILCATCHER_PORT:-1080}:1080"
      - "${MAILCATCHER_SMTP_PORT:-1025}:1025"
    networks:
      - <%= names.kebabCase %>-network
    restart: unless-stopped
  <% } %>

# Named volumes for data persistence
volumes:
  app_logs:
    driver: local
  <% if (variables.database === 'postgresql' || variables.database === 'postgres') { %>
  postgres_data:
    driver: local
  <% } else if (variables.database === 'mysql') { %>
  mysql_data:
    driver: local
  <% } else if (variables.database === 'mongodb') { %>
  mongodb_data:
    driver: local
  <% } %>
  <% if (variables.redis) { %>
  redis_data:
    driver: local
  <% } %>
  <% if (variables.nginx) { %>
  nginx_logs:
    driver: local
  <% } %>
  <% if (variables.monitoring) { %>
  prometheus_data:
    driver: local
  grafana_data:
    driver: local
  <% } %>

# Custom network
networks:
  <%= names.kebabCase %>-network:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/16