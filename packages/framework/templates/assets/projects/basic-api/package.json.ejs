{
  "name": "<%= names.kebabCase %>",
  "version": "0.1.0",
  "description": "<%= variables.description || 'A Brickend API project' %>",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "api",
    "brickend",
    "typescript"<% if (variables.keywords) { %>,<% variables.keywords.forEach(function(keyword) { %>
    "<%= keyword %>"<% if (variables.keywords.indexOf(keyword) !== variables.keywords.length - 1) { %>,<% } %><% }); %><% } %>
  ],
  "author": "<%= variables.author || '' %>",
  "license": "<%= variables.license || 'MIT' %>",
  "dependencies": {
    "@brickend/core": "*"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "eslint": "^9.27.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.14",
    "ts-jest": "^29.3.4"
  },
  "engines": {
    "node": ">=22"
  }
}