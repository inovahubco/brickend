# <%= names.pascalCase %> API Environment Variables
# Copy this file to .env and update the values

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Logging
LOG_LEVEL=info

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

<% if (variables.database) { %>
# Database Configuration
DATABASE_URL=your_database_url_here
<% } %>

<% if (variables.auth) { %>
# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h
<% } %>

<% if (variables.customEnvVars) { %>
<% variables.customEnvVars.forEach(function(envVar) { %>
# <%= envVar.description || envVar.name %>
<%= envVar.name %>=<%= envVar.defaultValue || 'your_value_here' %>
<% }); %>
<% } %>