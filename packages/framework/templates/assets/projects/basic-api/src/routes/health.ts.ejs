/**
 * Health Check Routes for <%= names.pascalCase %> API
 * Generated by Brickend on <%= now() %>
 */

import { createPlugin } from '@brickend/core';

export const healthPlugin = createPlugin('<%= names.kebabCase %>-health', async (fastify) => {
  
  // Basic health check endpoint
  fastify.get('/health', {
    schema: {
      description: 'Health check endpoint',
      tags: ['Health'],
      response: {
        200: {
          type: 'object',
          properties: {
            status: { type: 'string' },
            timestamp: { type: 'string' },
            uptime: { type: 'number' },
            version: { type: 'string' },
            environment: { type: 'string' },
            memory: {
              type: 'object',
              properties: {
                used: { type: 'number' },
                total: { type: 'number' },
                free: { type: 'number' }
              }
            }<% if (variables.database) { %>,
            database: {
              type: 'object',
              properties: {
                status: { type: 'string' },
                responseTime: { type: 'number' }
              }
            }<% } %><% if (variables.redis) { %>,
            cache: {
              type: 'object',
              properties: {
                status: { type: 'string' },
                responseTime: { type: 'number' }
              }
            }<% } %>
          }
        }
      }
    }
  }, async (request, reply) => {
    const memoryUsage = process.memoryUsage();
    
    const healthData = {
      status: 'healthy',
      timestamp: new Date().toISOString(),
      uptime: process.uptime(),
      version: process.env.npm_package_version || '0.1.0',
      environment: process.env.NODE_ENV || 'development',
      memory: {
        used: Math.round(memoryUsage.heapUsed / 1024 / 1024), // MB
        total: Math.round(memoryUsage.heapTotal / 1024 / 1024), // MB
        free: Math.round((memoryUsage.heapTotal - memoryUsage.heapUsed) / 1024 / 1024) // MB
      }
    };

    <% if (variables.database) { %>
    // Database health check
    try {
      const dbStart = Date.now();
      // Add your database ping/health check here
      // await database.ping();
      const dbTime = Date.now() - dbStart;
      
      healthData.database = {
        status: 'connected',
        responseTime: dbTime
      };
    } catch (error) {
      healthData.database = {
        status: 'disconnected',
        responseTime: -1
      };
      healthData.status = 'degraded';
    }
    <% } %>

    <% if (variables.redis) { %>
    // Redis/Cache health check
    try {
      const cacheStart = Date.now();
      // Add your cache ping/health check here
      // await redis.ping();
      const cacheTime = Date.now() - cacheStart;
      
      healthData.cache = {
        status: 'connected',
        responseTime: cacheTime
      };
    } catch (error) {
      healthData.cache = {
        status: 'disconnected',
        responseTime: -1
      };
      healthData.status = 'degraded';
    }
    <% } %>

    // Set appropriate status code
    const statusCode = healthData.status === 'healthy' ? 200 : 503;
    
    return reply.status(statusCode).send(healthData);
  });

  // Detailed health check with dependencies
  fastify.get('/health/detailed', {
    schema: {
      description: 'Detailed health check with dependency status',
      tags: ['Health'],
      response: {
        200: {
          type: 'object',
          properties: {
            status: { type: 'string' },
            timestamp: { type: 'string' },
            checks: {
              type: 'object',
              properties: {
                system: {
                  type: 'object',
                  properties: {
                    status: { type: 'string' },
                    uptime: { type: 'number' },
                    memory: { type: 'object' },
                    cpu: { type: 'object' }
                  }
                }<% if (variables.database) { %>,
                database: {
                  type: 'object',
                  properties: {
                    status: { type: 'string' },
                    responseTime: { type: 'number' },
                    connections: { type: 'number' }
                  }
                }<% } %><% if (variables.redis) { %>,
                cache: {
                  type: 'object',
                  properties: {
                    status: { type: 'string' },
                    responseTime: { type: 'number' },
                    memory: { type: 'string' }
                  }
                }<% } %>
              }
            }
          }
        }
      }
    }
  }, async (request, reply) => {
    const memoryUsage = process.memoryUsage();
    const cpuUsage = process.cpuUsage();
    
    const checks = {
      system: {
        status: 'healthy',
        uptime: process.uptime(),
        memory: {
          heapUsed: Math.round(memoryUsage.heapUsed / 1024 / 1024),
          heapTotal: Math.round(memoryUsage.heapTotal / 1024 / 1024),
          external: Math.round(memoryUsage.external / 1024 / 1024),
          rss: Math.round(memoryUsage.rss / 1024 / 1024)
        },
        cpu: {
          user: cpuUsage.user,
          system: cpuUsage.system
        }
      }
    };

    let overallStatus = 'healthy';

    <% if (variables.database) { %>
    // Database detailed check
    try {
      const dbStart = Date.now();
      // Add comprehensive database health check
      // const dbStats = await database.getStats();
      const dbTime = Date.now() - dbStart;
      
      checks.database = {
        status: 'connected',
        responseTime: dbTime,
        connections: 0 // dbStats.activeConnections
      };
    } catch (error) {
      checks.database = {
        status: 'error',
        responseTime: -1,
        connections: -1,
        error: error.message
      };
      overallStatus = 'unhealthy';
    }
    <% } %>

    <% if (variables.redis) { %>
    // Cache detailed check
    try {
      const cacheStart = Date.now();
      // Add comprehensive cache health check
      // const cacheInfo = await redis.info();
      const cacheTime = Date.now() - cacheStart;
      
      checks.cache = {
        status: 'connected',
        responseTime: cacheTime,
        memory: '0MB' // Parse from cacheInfo
      };
    } catch (error) {
      checks.cache = {
        status: 'error',
        responseTime: -1,
        memory: 'unknown',
        error: error.message
      };
      overallStatus = 'unhealthy';
    }
    <% } %>

    const healthData = {
      status: overallStatus,
      timestamp: new Date().toISOString(),
      checks
    };

    const statusCode = overallStatus === 'healthy' ? 200 : 503;
    return reply.status(statusCode).send(healthData);
  });

  // Readiness probe (for Kubernetes)
  fastify.get('/health/ready', {
    schema: {
      description: 'Readiness probe for container orchestration',
      tags: ['Health'],
      response: {
        200: {
          type: 'object',
          properties: {
            status: { type: 'string' },
            timestamp: { type: 'string' }
          }
        }
      }
    }
  }, async (request, reply) => {
    // Check if all critical dependencies are ready
    let ready = true;
    const issues = [];

    <% if (variables.database) { %>
    // Check database readiness
    try {
      // await database.ping();
    } catch (error) {
      ready = false;
      issues.push('database');
    }
    <% } %>

    <% if (variables.redis) { %>
    // Check cache readiness
    try {
      // await redis.ping();
    } catch (error) {
      ready = false;
      issues.push('cache');
    }
    <% } %>

    const response = {
      status: ready ? 'ready' : 'not-ready',
      timestamp: new Date().toISOString(),
      ...(issues.length > 0 && { issues })
    };

    return reply.status(ready ? 200 : 503).send(response);
  });

  // Liveness probe (for Kubernetes)
  fastify.get('/health/live', {
    schema: {
      description: 'Liveness probe for container orchestration',
      tags: ['Health'],
      response: {
        200: {
          type: 'object',
          properties: {
            status: { type: 'string' },
            timestamp: { type: 'string' },
            uptime: { type: 'number' }
          }
        }
      }
    }
  }, async (request, reply) => {
    // Simple liveness check - if we can respond, we're alive
    return {
      status: 'alive',
      timestamp: new Date().toISOString(),
      uptime: process.uptime()
    };
  });

  <% if (variables.metrics) { %>
  // Metrics endpoint (Prometheus compatible)
  fastify.get('/health/metrics', {
    schema: {
      description: 'Application metrics in Prometheus format',
      tags: ['Health', 'Metrics'],
      response: {
        200: {
          type: 'string'
        }
      }
    }
  }, async (request, reply) => {
    const memoryUsage = process.memoryUsage();
    const uptime = process.uptime();
    
    let metrics = `
# HELP nodejs_memory_heap_used_bytes Node.js heap memory used
# TYPE nodejs_memory_heap_used_bytes gauge
nodejs_memory_heap_used_bytes ${memoryUsage.heapUsed}

# HELP nodejs_memory_heap_total_bytes Node.js heap memory total
# TYPE nodejs_memory_heap_total_bytes gauge
nodejs_memory_heap_total_bytes ${memoryUsage.heapTotal}

# HELP nodejs_process_uptime_seconds Node.js process uptime
# TYPE nodejs_process_uptime_seconds counter
nodejs_process_uptime_seconds ${uptime}

# HELP http_requests_total Total number of HTTP requests
# TYPE http_requests_total counter
http_requests_total{method="GET",status="200"} 1
`.trim();

    return reply
      .header('Content-Type', 'text/plain; charset=utf-8')
      .send(metrics);
  });
  <% } %>
});