/**
 * Response utilities for Supabase Edge Functions
 * Generated by Brickend Framework
 */

export interface ApiResponse<T = any> {
  success: boolean;
  data?: T;
  error?: string;
  message?: string;
  meta?: {
    total?: number;
    page?: number;
    limit?: number;
    timestamp: string;
  };
}

export interface ErrorDetails {
  code: string;
  message: string;
  details?: any;
  field?: string;
}

/**
 * Create a success response
 */
export function createSuccessResponse<T>(
  data: T,
  message?: string,
  meta?: Partial<ApiResponse<T>['meta']>
): Response {
  const response: ApiResponse<T> = {
    success: true,
    data,
    ...(message && { message }),
    meta: {
      timestamp: new Date().toISOString(),
      ...meta,
    },
  };

  return new Response(JSON.stringify(response), {
    status: 200,
    headers: { 'Content-Type': 'application/json' },
  });
}

/**
 * Create an error response
 */
export function createErrorResponse(
  error: string | ErrorDetails,
  status: number = 400,
  details?: any
): Response {
  const errorDetails: ErrorDetails = typeof error === 'string' 
    ? { code: 'GENERIC_ERROR', message: error }
    : error;

  const response: ApiResponse = {
    success: false,
    error: errorDetails.message,
    meta: {
      timestamp: new Date().toISOString(),
    },
    ...(details && { details }),
  };

  return new Response(JSON.stringify(response), {
    status,
    headers: { 'Content-Type': 'application/json' },
  });
}

/**
 * Create a validation error response
 */
export function createValidationErrorResponse(
  field: string,
  message: string,
  details?: any
): Response {
  const errorDetails: ErrorDetails = {
    code: 'VALIDATION_ERROR',
    message,
    field,
    details,
  };

  return createErrorResponse(errorDetails, 422);
}

/**
 * Create a not found response
 */
export function createNotFoundResponse(resource: string = 'Resource'): Response {
  const errorDetails: ErrorDetails = {
    code: 'NOT_FOUND',
    message: `${resource} not found`,
  };

  return createErrorResponse(errorDetails, 404);
}

/**
 * Create an unauthorized response
 */
export function createUnauthorizedResponse(message?: string): Response {
  const errorDetails: ErrorDetails = {
    code: 'UNAUTHORIZED',
    message: message || 'Authentication required',
  };

  return createErrorResponse(errorDetails, 401);
}

/**
 * Create a forbidden response
 */
export function createForbiddenResponse(message?: string): Response {
  const errorDetails: ErrorDetails = {
    code: 'FORBIDDEN',
    message: message || 'Access denied',
  };

  return createErrorResponse(errorDetails, 403);
}

/**
 * Create a server error response
 */
export function createServerErrorResponse(message?: string, details?: any): Response {
  const errorDetails: ErrorDetails = {
    code: 'INTERNAL_ERROR',
    message: message || 'Internal server error',
    details,
  };

  return createErrorResponse(errorDetails, 500);
}

/**
 * Create a paginated response
 */
export function createPaginatedResponse<T>(
  data: T[],
  total: number,
  page: number,
  limit: number,
  message?: string
): Response {
  const totalPages = Math.ceil(total / limit);
  
  return createSuccessResponse(data, message, {
    total,
    page,
    limit,
    totalPages,
    hasNext: page < totalPages,
    hasPrev: page > 1,
  } as any);
}

/**
 * Create a created response (201)
 */
export function createCreatedResponse<T>(
  data: T,
  message?: string
): Response {
  const response: ApiResponse<T> = {
    success: true,
    data,
    message: message || 'Resource created successfully',
    meta: {
      timestamp: new Date().toISOString(),
    },
  };

  return new Response(JSON.stringify(response), {
    status: 201,
    headers: { 'Content-Type': 'application/json' },
  });
}

/**
 * Create a no content response (204)
 */
export function createNoContentResponse(): Response {
  return new Response(null, {
    status: 204,
  });
}

/**
 * Handle async operations with automatic error responses
 */
export async function handleAsync<T>(
  operation: () => Promise<T>,
  errorMessage?: string
): Promise<Response | T> {
  try {
    return await operation();
  } catch (error) {
    console.error('Operation failed:', error);
    
    const message = errorMessage || 'Operation failed';
    const details = error instanceof Error ? error.message : String(error);
    
    return createServerErrorResponse(message, details);
  }
}

/**
 * Convert Supabase error to appropriate HTTP response
 */
export function handleSupabaseError(error: any): Response {
  console.error('Supabase error:', error);

  // Handle specific Supabase error codes
  if (error.code) {
    switch (error.code) {
      case 'PGRST116': // Row not found
        return createNotFoundResponse();
      
      case '23505': // Unique violation
        return createValidationErrorResponse(
          'duplicate',
          'Resource already exists',
          error.details
        );
      
      case '23503': // Foreign key violation
        return createValidationErrorResponse(
          'reference',
          'Referenced resource does not exist',
          error.details
        );
      
      case '23514': // Check violation
        return createValidationErrorResponse(
          'constraint',
          'Data violates constraints',
          error.details
        );
      
      default:
        return createServerErrorResponse(
          'Database operation failed',
          error.message
        );
    }
  }

  // Handle generic errors
  return createServerErrorResponse(
    error.message || 'An unexpected error occurred',
    error
  );
}