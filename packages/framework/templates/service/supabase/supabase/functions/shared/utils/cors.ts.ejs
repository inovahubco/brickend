// Handle CORS preflight request
export function handleCorsPreflightRequest(request: Request, config?: CorsConfig): Response {
  const corsConfig = config || getCorsConfig();
  const requestInfo = parseCorsRequest(request);
  const validation = validateCorsRequest(requestInfo, corsConfig);
  
  if (!validation.allowed) {
    return new Response(null, {
      status: 403,
      headers: {
        'Content-Type': 'text/plain'
