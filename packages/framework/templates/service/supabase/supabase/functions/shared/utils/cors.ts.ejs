// Check if origin is allowed
export function isOriginAllowed(origin: string | undefined, allowedOrigins: CorsConfig['origin']): boolean {
  if (!origin && allowedOrigins !== false) {
    return true; // No origin header (mobile apps, etc.)
  }
  
  if (allowedOrigins === true) {
    return true;
  }
  
  if (allowedOrigins === false) {
    return false;
  }
  
  if (typeof allowedOrigins === 'function') {
    return allowedOrigins(origin || '');
  }
  
  if (Array.isArray(allowedOrigins)) {
    return allowedOrigins.includes(origin || '');
  }
  
  if (typeof allowedOrigins === 'string') {
    return allowedOrigins === origin;
  }
  
  return false;
}

// Check if method is allowed
export function isMethodAllowed(method: string, allowedMethods: string[]): boolean {
  return allowedMethods.includes(method.toUpperCase());
}

// Check if header is allowed
export function isHeaderAllowed(header: string, allowedHeaders: string[]): boolean {
  const normalizedHeader = header.toLowerCase();
  const normalizedAllowed = allowedHeaders.map(h => h.toLowerCase());
  
  return normalizedAllowed.includes(normalizedHeader);
}

