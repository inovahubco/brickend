  <%= field.name %>: <%= generateZodSchema(field) %><%= isOptional && !field.validation?.required ? '.optional()' : '' %><%= index < entity.fields.length - 1 ? ',' : '' %>
<% }); -%>
});

// <%= entity.name %> update schema (all fields optional)
