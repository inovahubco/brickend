// Function to generate Zod schema for a field
function generateZodSchema(field) {
  let schema = '';

  // Base type
  switch (field.type) {
    case 'string':
    case 'text':
      schema = 'z.string()';
      break;
    case 'email':
      schema = 'z.string().email()';
      break;
    case 'url':
      schema = 'z.string().url()';
      break;
    case 'uuid':
      schema = 'z.string().uuid()';
      break;
    case 'number':
    case 'integer':
      schema = 'z.number().int()';
      break;
    case 'float':
    case 'decimal':
      schema = 'z.number()';
      break;
    case 'boolean':
      schema = 'z.boolean()';
      break;
    case 'date':
      schema = 'z.string().date()';
      break;
    case 'datetime':
      schema = 'z.string().datetime()';
      break;
    case 'json':
      schema = 'z.any()';
      break;
    default:
      schema = 'z.string()';
  }

  // Add validation rules
  if (field.validation) {
    if (field.validation.minLength) {
      schema += `.min(${field.validation.minLength})`;
    }
    if (field.validation.maxLength) {
      schema += `.max(${field.validation.maxLength})`;
    }
    if (field.validation.min && ['number', 'integer', 'float', 'decimal'].includes(field.type)) {
      schema += `.min(${field.validation.min})`;
    }
    if (field.validation.max && ['number', 'integer', 'float', 'decimal'].includes(field.type)) {
      schema += `.max(${field.validation.max})`;
    }
    if (field.validation.pattern) {
      schema += `.regex(/${field.validation.pattern}/)`;
    }
    if (field.validation.enum && field.validation.enum.length > 0) {
      schema += `.enum([${field.validation.enum.map(v => `"${v}"`).join(', ')}])`;
    }
  }

  // Make optional if not required
  if (!field.validation?.required || field.options?.nullable) {
    schema += '.optional()';
  }

  return schema;
}
-%>

