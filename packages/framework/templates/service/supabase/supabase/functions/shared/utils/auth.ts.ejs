// Extract user from JWT token
export async function getUserFromToken(token: string): Promise<User | null> {
  try {
    const supabase = createAuthClient();
    const { data: { user }, error } = await supabase.auth.getUser(token);
    
    if (error || !user) {
      console.error('Failed to get user from token:', error?.message);
      return null;
    }
    
    return user;
  } catch (error) {
    console.error('Error extracting user from token:', error);
    return null;
  }
}

// Validate session and get user
export async function validateSession(accessToken: string): Promise<{ user: User; valid: boolean } | null> {
  try {
    const supabase = createAuthClient();
    const { data, error } = await supabase.auth.getUser(accessToken);
    
    if (error || !data.user) {
      return null;
    }
    
    return {
      user: data.user,
      valid: true
    };
  } catch (error) {
    console.error('Session validation failed:', error);
    return null;
  }
}

// Get user profile with additional data
export async function getUserProfile(userId: string): Promise<AuthUser | null> {
  try {
    const supabase = createAdminClient();
    
    // Get user from auth
    const { data: user, error: userError } = await supabase.auth.admin.getUserById(userId);
    if (userError || !user.user) {
      return null;
    }
    
    // Get profile data
    const { data: profile, error: profileError } = await supabase
      .from('profiles')
      .select('*')
      .eq('id', userId)
      .single();
    
    if (profileError && profileError.code !== 'PGRST116') {
      console.error('Failed to get profile:', profileError);
    }
    
    return {
      ...user.user,
      profile: profile || undefined
    };
  } catch (error) {
    console.error('Error getting user profile:', error);
    return null;
  }
}

// Build authentication context
export async function buildAuthContext(token: string): Promise<AuthContext | null> {
  try {
    const user = await getUserFromToken(token);
    if (!user) {
      return null;
    }
    
    const profile = await getUserProfile(user.id);
    if (!profile) {
      return null;
    }
    
    const role = getUserRole(profile);
    const permissions = getUserPermissions(profile);
    const isAdmin = hasRole(profile, UserRole.ADMIN);
    
    return {
      user: profile,
      token,
      isAuthenticated: true,
      isAdmin,
      permissions,
      role
    };
  } catch (error) {
    console.error('Failed to build auth context:', error);
    return null;
  }
}

// Extract user role from user data
export function getUserRole(user: AuthUser): string {
  return user.user_metadata?.role || 
         user.app_metadata?.role || 
         user.profile?.role || 
         UserRole.USER;
}

// Extract user permissions from user data
export function getUserPermissions(user: AuthUser): string[] {
  const role = getUserRole(user);
  const customPermissions = user.user_metadata?.permissions || 
                           user.app_metadata?.permissions || 
                           user.profile?.permissions || 
                           [];
  
  // Get role-based permissions
  const rolePermissions = ROLE_PERMISSIONS[role as UserRole] || ROLE_PERMISSIONS[UserRole.USER];
  
  // Combine role permissions with custom permissions
  return [...new Set([...rolePermissions, ...customPermissions])];
}

// Check if user has specific role
export function hasRole(user: AuthUser, role: UserRole): boolean {
  const userRole = getUserRole(user);
  return userRole === role;
}

// Check if user has any of the specified roles
export function hasAnyRole(user: AuthUser, roles: UserRole[]): boolean {
  const userRole = getUserRole(user);
  return roles.includes(userRole as UserRole);
}

// Check if user has specific permission
export function hasPermission(user: AuthUser, permission: string): boolean {
  const userPermissions = getUserPermissions(user);
  return userPermissions.includes(permission);
}

// Check if user has any of the specified permissions
export function hasAnyPermission(user: AuthUser, permissions: string[]): boolean {
  const userPermissions = getUserPermissions(user);
  return permissions.some(permission => userPermissions.includes(permission));
}

// Check if user has all specified permissions
export function hasAllPermissions(user: AuthUser, permissions: string[]): boolean {
  const userPermissions = getUserPermissions(user);
  return permissions.every(permission => userPermissions.includes(permission));
}

// Validate permission with detailed result
export function validatePermission(user: AuthUser, requiredPermission: string | string[]): PermissionCheck {
  const userPermissions = getUserPermissions(user);
  const required = Array.isArray(requiredPermission) ? requiredPermission : [requiredPermission];
  
  if (Array.isArray(requiredPermission)) {
    const granted = hasAnyPermission(user, requiredPermission);
    return {
      granted,
      required: requiredPermission,
      userPermissions,
      reason: granted ? undefined : `User lacks one of required permissions: ${requiredPermission.join(', ')}`
    };
  } else {
    const granted = hasPermission(user, requiredPermission);
    return {
      granted,
      required: requiredPermission,
      userPermissions,
      reason: granted ? undefined : `User lacks required permission: ${requiredPermission}`
    };
  }
}

// Check if user owns resource
export function checkResourceOwnership(
  user: AuthUser, 
  resource: any, 
  ownerField: string = 'user_id'
): boolean {
  if (!resource || !user) {
    return false;
  }
  
  const resourceOwnerId = resource[ownerField] || 
                         resource.owner_id || 
                         resource.created_by;
  
  return resourceOwnerId === user.id;
}

// Generate permission string
export function buildPermission(resource: string, action: string, scope?: string): string {
  return scope ? `${resource}:${action}:${scope}` : `${resource}:${action}`;
}

// Parse permission string
export function parsePermission(permission: string): { resource: string; action: string; scope?: string } {
  const parts = permission.split(':');
  return {
    resource: parts[0],
    action: parts[1],
    scope: parts[2]
  };
}

