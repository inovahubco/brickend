// Rate limiting for authentication attempts
const authAttempts = new Map<string, { count: number; lastAttempt: number; blockedUntil?: number }>();

export function checkAuthRateLimit(
  identifier: string,
  maxAttempts: number = 5,
  windowMs: number = 15 * 60 * 1000, // 15 minutes
  blockDurationMs: number = 60 * 60 * 1000 // 1 hour
): { allowed: boolean; remaining: number; resetTime?: number; blockedUntil?: number } {
  const now = Date.now();
  const attempts = authAttempts.get(identifier) || { count: 0, lastAttempt: 0 };
  
  // Check if currently blocked
  if (attempts.blockedUntil && now < attempts.blockedUntil) {
    return {
      allowed: false,
      remaining: 0,
      blockedUntil: attempts.blockedUntil
    };
  }
  
  // Reset window if enough time has passed
  if (now - attempts.lastAttempt > windowMs) {
    attempts.count = 0;
    attempts.blockedUntil = undefined;
  }
  
  // Check if limit exceeded
  if (attempts.count >= maxAttempts) {
    attempts.blockedUntil = now + blockDurationMs;
    authAttempts.set(identifier, attempts);
    return {
      allowed: false,
      remaining: 0,
      blockedUntil: attempts.blockedUntil
    };
  }
  
  return {
    allowed: true,
    remaining: maxAttempts - attempts.count,
    resetTime: attempts.lastAttempt + windowMs
  };
}

export function recordAuthAttempt(identifier: string): void {
  const now = Date.now();
  const attempts = authAttempts.get(identifier) || { count: 0, lastAttempt: 0 };
  
  attempts.count += 1;
  attempts.lastAttempt = now;
  
  authAttempts.set(identifier, attempts);
}

// JWT token utilities
export function extractTokenFromHeader(authHeader: string | null): string | null {
  if (!authHeader) {
    return null;
  }
  
  const match = authHeader.match(/^Bearer\s+(.+)$/);
  return match ? match[1] : null;
}

// Create authentication error
export function createAuthError(
  code: string,
  message: string,
  statusCode: number = 401,
  details?: any
): Response {
  return new Response(
    JSON.stringify({
      error: {
        code,
        message,
        details,
        timestamp: new Date().toISOString()
      }
    }),
    {
      status: statusCode,
      headers: { 'Content-Type': 'application/json' }
    }
  );
}

