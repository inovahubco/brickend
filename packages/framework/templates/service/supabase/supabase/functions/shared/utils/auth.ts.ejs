  [UserRole.ADMIN]: [UserRole.ADMIN, UserRole.MODERATOR, UserRole.USER, UserRole.GUEST],
  [UserRole.MODERATOR]: [UserRole.MODERATOR, UserRole.USER, UserRole.GUEST],
  [UserRole.USER]: [UserRole.USER, UserRole.GUEST],
  [UserRole.GUEST]: [UserRole.GUEST]
};

// Check if user role has access to target role's permissions
export function roleIncludes(userRole: UserRole, targetRole: UserRole): boolean {
  return roleHierarchy[userRole]?.includes(targetRole) || false;
}

// Get effective permissions including role hierarchy
export function getEffectivePermissions(user: AuthUser): string[] {
  const userRole = getUserRole(user) as UserRole;
  const allowedRoles = roleHierarchy[userRole] || [UserRole.GUEST];
  
  // Collect permissions from all allowed roles
  const allPermissions = allowedRoles.flatMap(role => 
    ROLE_PERMISSIONS[role] || []
  );
  
  // Add custom permissions
  const customPermissions = user.user_metadata?.permissions || 
                           user.app_metadata?.permissions || 
                           user.profile?.permissions || 
                           [];
  
  return [...new Set([...allPermissions, ...customPermissions])];
}

