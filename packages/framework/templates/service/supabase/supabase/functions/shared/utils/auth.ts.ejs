<% entities.forEach(entity => { -%>
export function can<%= utils.pascalCase(entity.name) %>(
  user: AuthUser, 
  action: 'create' | 'read' | 'update' | 'delete' | 'admin',
  resource?: any
): boolean {
  const entityName = '<%= entity.name.toLowerCase() %>';
  
  // Check admin permission
  if (hasPermission(user, `${entityName}:admin`)) {
    return true;
  }
  
  // Check specific action permission
  if (hasPermission(user, `${entityName}:${action}`)) {
    return true;
  }
  
  // Check scoped permission for update/delete
  if ((action === 'update' || action === 'delete') && resource) {
    if (hasPermission(user, `${entityName}:${action}:own`)) {
      return checkResourceOwnership(user, resource);
    }
  }
  
  return false;
}

