/**
 * <%= entity.pascalName %> API Router
 * Generated by Brickend Framework
 * 
 * Routes:
 * GET    /<%= entity.kebabName %>        - List <%= entity.pluralName %> (paginated)
 * GET    /<%= entity.kebabName %>/:id    - Get <%= entity.camelName %> by ID
 * POST   /<%= entity.kebabName %>        - Create new <%= entity.camelName %>
 * PUT    /<%= entity.kebabName %>/:id    - Update <%= entity.camelName %> by ID
 * PATCH  /<%= entity.kebabName %>/:id    - Partial update <%= entity.camelName %> by ID
 * DELETE /<%= entity.kebabName %>/:id    - Delete <%= entity.camelName %> by ID
 * <% if (entity.hasSoftDelete) { %>
 * PATCH  /<%= entity.kebabName %>/:id?action=restore - Restore soft-deleted <%= entity.camelName %>
 * <% } %>
 */

import { corsHeaders } from '../shared/utils/cors.ts';
import {
  createErrorResponse,
  createSuccessResponse,
} from '../shared/utils/response.ts';

// Import CRUD handlers
import createHandler from './create.ts';
import readHandler from './read.ts';
import updateHandler from './update.ts';
import deleteHandler from './delete.ts';

/**
 * Handle OPTIONS request for CORS
 */
function handleOptions(): Response {
  return new Response('ok', { headers: corsHeaders });
}

/**
 * Route request to appropriate handler based on method and path
 */
async function routeRequest(request: Request): Promise<Response> {
  const url = new URL(request.url);
  const method = request.method;
  
  // Log request for debugging
  console.log(`[<%= entity.pascalName %>] ${method} ${url.pathname}`);

  try {
    switch (method) {
      case 'GET':
        return await readHandler(request);
      
      case 'POST':
        return await createHandler(request);
      
      case 'PUT':
      case 'PATCH':
        // Check if this is a restore action
        if (method === 'PATCH' && url.searchParams.get('action') === 'restore') {
          return await deleteHandler(request);
        }
        return await updateHandler(request);
      
      case 'DELETE':
        return await deleteHandler(request);
      
      default:
        return createErrorResponse(
          `Method ${method} not allowed`,
          405
        );
    }
  } catch (error) {
    console.error(`[<%= entity.pascalName %>] Routing error:`, error);
    return createErrorResponse(
      'Internal server error',
      500
    );
  }
}

