/**
 * Delete <%= entity.name %> endpoint
 * Generated by Brickend Framework
 */

import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';
import { corsHeaders } from '../shared/utils/cors.ts';
import { validateAuth } from '../shared/utils/auth.ts';
import {
  createSuccessResponse,
  createErrorResponse,
  createValidationErrorResponse,
  createNotFoundResponse,
  createNoContentResponse,
  handleSupabaseError,
  handleAsync,
} from '../shared/utils/response.ts';
import type { 
  <%= entity.pascalName %>, 
  Database 
} from '../shared/interfaces/database.ts';

/**
 * Handle OPTIONS request for CORS
 */
function handleOptions(): Response {
  return new Response('ok', { headers: corsHeaders });
}

/**
 * Soft delete a <%= entity.camelName %> by ID
 */
async function softDelete<%= entity.pascalName %>(
  supabase: any,
  id: string,
  userId: string
): Promise<Response> {
  return handleAsync(async () => {
    // Check if the record exists and user has permission
    const { data: existing<%= entity.pascalName %>, error: fetchError } = await supabase
      .from('<%= entity.tableName %>')
      .select('*')
      .eq('id', id)
      <% if (entity.hasSoftDelete) { %>
      .is('deleted_at', null)
      <% } %>
      .single();

    if (fetchError) {
      if (fetchError.code === 'PGRST116') {
        return createNotFoundResponse('<%= entity.pascalName %>');
      }
      return handleSupabaseError(fetchError);
    }

    if (!existing<%= entity.pascalName %>) {
      return createNotFoundResponse('<%= entity.pascalName %>');
    }

    <% if (entity.hasOwnership) { %>
    // Check ownership permission
    if (existing<%= entity.pascalName %>.created_by !== userId) {
      return createErrorResponse('Access denied', 403);
    }
    <% } %>

    <% if (entity.hasSoftDelete) { %>
    // Perform soft delete
    const { data: deleted<%= entity.pascalName %>, error: deleteError } = await supabase
      .from('<%= entity.tableName %>')
      .update({
        deleted_at: new Date().toISOString(),
        <% if (entity.hasAuditFields) { %>
        updated_by: userId,
        updated_at: new Date().toISOString(),
        <% } %>
      })
      .eq('id', id)
      .select()
      .single();

    if (deleteError) {
      return handleSupabaseError(deleteError);
    }

    return createSuccessResponse(
      deleted<%= entity.pascalName %>,
      '<%= entity.pascalName %> deleted successfully'
    );
    <% } else { %>
    return createErrorResponse(
      'Soft delete not supported for this entity',
      400
    );
    <% } %>
  }, 'Failed to delete <%= entity.camelName %>');
}

/**
 * Hard delete a <%= entity.camelName %> by ID
 */
async function hardDelete<%= entity.pascalName %>(
  supabase: any,
  id: string,
  userId: string
): Promise<Response> {
  return handleAsync(async () => {
    // Check if the record exists and user has permission
    const { data: existing<%= entity.pascalName %>, error: fetchError } = await supabase
      .from('<%= entity.tableName %>')
      .select('*')
      .eq('id', id)
      .single();

    if (fetchError) {
      if (fetchError.code === 'PGRST116') {
        return createNotFoundResponse('<%= entity.pascalName %>');
      }
      return handleSupabaseError(fetchError);
    }

    if (!existing<%= entity.pascalName %>) {
      return createNotFoundResponse('<%= entity.pascalName %>');
    }

    <% if (entity.hasOwnership) { %>
    // Check ownership permission
    if (existing<%= entity.pascalName %>.created_by !== userId) {
      return createErrorResponse('Access denied', 403);
    }
    <% } %>

    // Perform hard delete
    const { error: deleteError } = await supabase
      .from('<%= entity.tableName %>')
      .delete()
      .eq('id', id);

    if (deleteError) {
      return handleSupabaseError(deleteError);
    }

    // Return 204 No Content for successful deletion
    return createNoContentResponse();
  }, 'Failed to delete <%= entity.camelName %>');
}

/**
 * Restore a soft-deleted <%= entity.camelName %> by ID
 */
async function restore<%= entity.pascalName %>(
  supabase: any,
  id: string,
  userId: string
): Promise<Response> {
  <% if (!entity.hasSoftDelete) { %>
  return createErrorResponse(
    'Restore not supported for this entity',
    400
  );
  <% } else { %>
  return handleAsync(async () => {
    // Check if the record exists and is soft-deleted
    const { data: existing<%= entity.pascalName %>, error: fetchError } = await supabase
      .from('<%= entity.tableName %>')
      .select('*')
      .eq('id', id)
      .not('deleted_at', 'is', null)
      .single();

    if (fetchError) {
      if (fetchError.code === 'PGRST116') {
        return createNotFoundResponse('Deleted <%= entity.pascalName %>');
      }
      return handleSupabaseError(fetchError);
    }

    if (!existing<%= entity.pascalName %>) {
      return createNotFoundResponse('Deleted <%= entity.pascalName %>');
    }

    <% if (entity.hasOwnership) { %>
    // Check ownership permission
    if (existing<%= entity.pascalName %>.created_by !== userId) {
      return createErrorResponse('Access denied', 403);
    }
    <% } %>

    // Restore the record
    const { data: restored<%= entity.pascalName %>, error: restoreError } = await supabase
      .from('<%= entity.tableName %>')
      .update({
        deleted_at: null,
        <% if (entity.hasAuditFields) { %>
        updated_by: userId,
        updated_at: new Date().toISOString(),
        <% } %>
      })
      .eq('id', id)
      .select()
      .single();

    if (restoreError) {
      return handleSupabaseError(restoreError);
    }

    return createSuccessResponse(
      restored<%= entity.pascalName %>,
      '<%= entity.pascalName %> restored successfully'
    );
  }, 'Failed to restore <%= entity.camelName %>');
  <% } %>
}

/**
 * Main handler function
 */
export default async function handler(request: Request): Promise<Response> {
  // Handle CORS preflight
  if (request.method === 'OPTIONS') {
    return handleOptions();
  }

  // Only allow DELETE and PATCH methods
  if (!['DELETE', 'PATCH'].includes(request.method)) {
    return createErrorResponse('Method not allowed', 405);
  }

  try {
    const supabase = createClient<Database>(
      Deno.env.get('SUPABASE_URL') ?? '',
      Deno.env.get('SUPABASE_ANON_KEY') ?? '',
      {
        global: {
          headers: { Authorization: request.headers.get('Authorization')! },
        },
      }
    );

    // Validate authentication
    const authResult = await validateAuth(supabase);
    if (!authResult.success) {
      return createErrorResponse(authResult.error, 401);
    }

    const user = authResult.user;
    const url = new URL(request.url);
    const pathSegments = url.pathname.split('/').filter(Boolean);
    const id = pathSegments[pathSegments.length - 1];

    if (!id) {
      return createValidationErrorResponse(
        'id',
        'ID parameter is required'
      );
    }

    // Validate ID format
    const isUuidPattern = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
    if (!isUuidPattern.test(id)) {
      return createValidationErrorResponse(
        'id',
        'Invalid ID format'
      );
    }

    let response: Response;

    if (request.method === 'DELETE') {
      // Check for force delete parameter
      const forceDelete = url.searchParams.get('force') === 'true';
      
      if (forceDelete) {
        response = await hardDelete<%= entity.pascalName %>(supabase, id, user.id);
      } else {
        <% if (entity.hasSoftDelete) { %>
        response = await softDelete<%= entity.pascalName %>(supabase, id, user.id);
        <% } else { %>
        response = await hardDelete<%= entity.pascalName %>(supabase, id, user.id);
        <% } %>
      }
    } else if (request.method === 'PATCH') {
      // Check for restore action
      const action = url.searchParams.get('action');
      
      if (action === 'restore') {
        response = await restore<%= entity.pascalName %>(supabase, id, user.id);
      } else {
        return createValidationErrorResponse(
          'action',
          'Invalid action. Supported actions: restore'
        );
      }
    } else {
      return createErrorResponse('Method not allowed', 405);
    }
    
    // Add CORS headers to response
    const headers = new Headers(response.headers);
    Object.entries(corsHeaders).forEach(([key, value]) => {
      headers.set(key, value);
    });

    return new Response(response.body, {
      status: response.status,
      headers,
    });
  } catch (error) {
    console.error('Unhandled error in delete <%= entity.camelName %>:', error);
    
    const errorResponse = createErrorResponse(
      'Internal server error',
      500
    );
    
    const headers = new Headers(errorResponse.headers);
    Object.entries(corsHeaders).forEach(([key, value]) => {
      headers.set(key, value);
    });

    return new Response(errorResponse.body, {
      status: errorResponse.status,
      headers,
    });
  }
}