/**
 * Read <%= entity.name %> endpoint
 * Generated by Brickend Framework
 */

import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';
import { corsHeaders } from '../shared/utils/cors.ts';
import { validateAuth } from '../shared/utils/auth.ts';
import {
  createSuccessResponse,
  createErrorResponse,
  createNotFoundResponse,
  createPaginatedResponse,
  handleSupabaseError,
  handleAsync,
} from '../shared/utils/response.ts';
import type { 
  <%= entity.pascalName %>, 
  Database 
} from '../shared/interfaces/database.ts';

/**
 * Handle OPTIONS request for CORS
 */
function handleOptions(): Response {
  return new Response('ok', { headers: corsHeaders });
}

/**
 * Get a single <%= entity.camelName %> by ID
 */
async function get<%= entity.pascalName %>ById(
  supabase: any, 
  id: string
): Promise<Response> {
  return handleAsync(async () => {
    const { data: <%= entity.camelName %>, error } = await supabase
      .from('<%= entity.tableName %>')
      .select('*')
      .eq('id', id)
      .single();

    if (error) {
      if (error.code === 'PGRST116') {
        return createNotFoundResponse('<%= entity.pascalName %>');
      }
      return handleSupabaseError(error);
    }

    if (!<%= entity.camelName %>) {
      return createNotFoundResponse('<%= entity.pascalName %>');
    }

    return createSuccessResponse(
      <%= entity.camelName %>,
      '<%= entity.pascalName %> retrieved successfully'
    );
  }, 'Failed to retrieve <%= entity.camelName %>');
}

/**
 * Get paginated list of <%= entity.pluralName %>
 */
async function get<%= entity.pascalName %>List(
  supabase: any,
  searchParams: URLSearchParams
): Promise<Response> {
  // Parse query parameters
  const page = Math.max(1, parseInt(searchParams.get('page') || '1'));
  const limit = Math.min(100, Math.max(1, parseInt(searchParams.get('limit') || '10')));
  const offset = (page - 1) * limit;
  
  // Search and filter parameters
  const search = searchParams.get('search') || '';
  const sortBy = searchParams.get('sortBy') || 'created_at';
  const sortOrder = searchParams.get('sortOrder') === 'asc' ? 'asc' : 'desc';
  
  return handleAsync(async () => {
    // Build query
    let query = supabase
      .from('<%= entity.tableName %>')
      .select('*', { count: 'exact' });

    // Apply search filter if provided
    <% if (entity.searchableFields && entity.searchableFields.length > 0) { %>
    if (search) {
      const searchConditions = [
        <% entity.searchableFields.forEach((field, index) => { %>
        `<%= field %>.ilike.%${search}%`<%= index < entity.searchableFields.length - 1 ? ',' : '' %>
        <% }); %>
      ];
      query = query.or(searchConditions.join(','));
    }
    <% } %>

    // Apply additional filters
    <% entity.filterableFields?.forEach(field => { %>
    const <%= field.name %> = searchParams.get('<%= field.name %>');
    if (<%= field.name %>) {
      query = query.eq('<%= field.name %>', <%= field.name %>);
    }
    <% }); %>

    // Apply sorting and pagination
    query = query
      .order(sortBy, { ascending: sortOrder === 'asc' })
      .range(offset, offset + limit - 1);

    const { data: <%= entity.pluralCamelName %>, error, count } = await query;

    if (error) {
      return handleSupabaseError(error);
    }

    return createPaginatedResponse(
      <%= entity.pluralCamelName %> || [],
      count || 0,
      page,
      limit,
      '<%= entity.pascalName %> list retrieved successfully'
    );
  }, 'Failed to retrieve <%= entity.pluralName %>');
}

/**
 * Main handler function
 */
export default async function handler(request: Request): Promise<Response> {
  // Handle CORS preflight
  if (request.method === 'OPTIONS') {
    return handleOptions();
  }

  // Only allow GET method
  if (request.method !== 'GET') {
    return createErrorResponse('Method not allowed', 405);
  }

  try {
    const supabase = createClient<Database>(
      Deno.env.get('SUPABASE_URL') ?? '',
      Deno.env.get('SUPABASE_ANON_KEY') ?? '',
      {
        global: {
          headers: { Authorization: request.headers.get('Authorization')! },
        },
      }
    );

    // Validate authentication
    const authResult = await validateAuth(supabase);
    if (!authResult.success) {
      return createErrorResponse(authResult.error, 401);
    }

    const url = new URL(request.url);
    const pathSegments = url.pathname.split('/').filter(Boolean);
    
    // Check if this is a request for a specific ID
    const lastSegment = pathSegments[pathSegments.length - 1];
    const isUuidPattern = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
    
    let response: Response;
    
    if (isUuidPattern.test(lastSegment)) {
      // Get single <%= entity.camelName %> by ID
      response = await get<%= entity.pascalName %>ById(supabase, lastSegment);
    } else {
      // Get paginated list of <%= entity.pluralName %>
      response = await get<%= entity.pascalName %>List(supabase, url.searchParams);
    }
    
    // Add CORS headers to response
    const headers = new Headers(response.headers);
    Object.entries(corsHeaders).forEach(([key, value]) => {
      headers.set(key, value);
    });

    return new Response(response.body, {
      status: response.status,
      headers,
    });
  } catch (error) {
    console.error('Unhandled error in read <%= entity.camelName %>:', error);
    
    const errorResponse = createErrorResponse(
      'Internal server error',
      500
    );
    
    const headers = new Headers(errorResponse.headers);
    Object.entries(corsHeaders).forEach(([key, value]) => {
      headers.set(key, value);
    });

    return new Response(errorResponse.body, {
      status: errorResponse.status,
      headers,
    });
  }
}