/**
 * Update <%= entity.name %> endpoint
 * Generated by Brickend Framework
 */

import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';
import { corsHeaders } from '../shared/utils/cors.ts';
import { validateAuth } from '../shared/utils/auth.ts';
import { <%= entity.pascalName %>UpdateSchema } from '../shared/utils/validation.ts';
import {
  createSuccessResponse,
  createErrorResponse,
  createValidationErrorResponse,
  createNotFoundResponse,
  handleSupabaseError,
  handleAsync,
} from '../shared/utils/response.ts';
import type { 
  <%= entity.pascalName %>, 
  <%= entity.pascalName %>Update,
  Database 
} from '../shared/interfaces/database.ts';

/**
 * Handle OPTIONS request for CORS
 */
function handleOptions(): Response {
  return new Response('ok', { headers: corsHeaders });
}

/**
 * Update a <%= entity.camelName %> by ID
 */
async function update<%= entity.pascalName %>(
  request: Request,
  id: string
): Promise<Response> {
  const supabase = createClient<Database>(
    Deno.env.get('SUPABASE_URL') ?? '',
    Deno.env.get('SUPABASE_ANON_KEY') ?? '',
    {
      global: {
        headers: { Authorization: request.headers.get('Authorization')! },
      },
    }
  );

  // Validate authentication
  const authResult = await validateAuth(supabase);
  if (!authResult.success) {
    return createErrorResponse(authResult.error, 401);
  }

  const user = authResult.user;

  // Validate ID format
  const isUuidPattern = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
  if (!isUuidPattern.test(id)) {
    return createValidationErrorResponse(
      'id',
      'Invalid ID format'
    );
  }

  // Parse and validate request body
  let body;
  try {
    body = await request.json();
  } catch (error) {
    return createValidationErrorResponse(
      'body',
      'Invalid JSON in request body'
    );
  }

  // Validate input schema
  const validation = <%= entity.pascalName %>UpdateSchema.safeParse(body);
  if (!validation.success) {
    const firstError = validation.error.errors[0];
    return createValidationErrorResponse(
      firstError.path.join('.'),
      firstError.message,
      validation.error.errors
    );
  }

  const data = validation.data;

  // Check if there are fields to update
  if (Object.keys(data).length === 0) {
    return createValidationErrorResponse(
      'body',
      'No fields provided for update'
    );
  }

  return handleAsync(async () => {
    // First, check if the record exists and user has permission to update it
    const { data: existing<%= entity.pascalName %>, error: fetchError } = await supabase
      .from('<%= entity.tableName %>')
      .select('*')
      .eq('id', id)
      .single();

    if (fetchError) {
      if (fetchError.code === 'PGRST116') {
        return createNotFoundResponse('<%= entity.pascalName %>');
      }
      return handleSupabaseError(fetchError);
    }

    if (!existing<%= entity.pascalName %>) {
      return createNotFoundResponse('<%= entity.pascalName %>');
    }

    <% if (entity.hasOwnership) { %>
    // Check ownership permission
    if (existing<%= entity.pascalName %>.created_by !== user.id) {
      return createErrorResponse('Access denied', 403);
    }
    <% } %>

    // Prepare update data with audit fields
    const updateData: <%= entity.pascalName %>Update = {
      ...data,
      <% if (entity.hasAuditFields) { %>
      updated_by: user.id,
      updated_at: new Date().toISOString(),
      <% } %>
    };

    // Perform the update
    const { data: updated<%= entity.pascalName %>, error: updateError } = await supabase
      .from('<%= entity.tableName %>')
      .update(updateData)
      .eq('id', id)
      .select()
      .single();

    if (updateError) {
      return handleSupabaseError(updateError);
    }

    if (!updated<%= entity.pascalName %>) {
      return createErrorResponse('Failed to update <%= entity.camelName %>', 500);
    }

    return createSuccessResponse(
      updated<%= entity.pascalName %>,
      '<%= entity.pascalName %> updated successfully'
    );
  }, 'Failed to update <%= entity.camelName %>');
}

/**
 * Patch a <%= entity.camelName %> by ID (partial update)
 */
async function patch<%= entity.pascalName %>(
  request: Request,
  id: string
): Promise<Response> {
  // For now, PATCH behaves the same as PUT
  // In the future, you might want to implement different logic
  return update<%= entity.pascalName %>(request, id);
}

/**
 * Main handler function
 */
export default async function handler(request: Request): Promise<Response> {
  // Handle CORS preflight
  if (request.method === 'OPTIONS') {
    return handleOptions();
  }

  // Only allow PUT and PATCH methods
  if (!['PUT', 'PATCH'].includes(request.method)) {
    return createErrorResponse('Method not allowed', 405);
  }

  try {
    const url = new URL(request.url);
    const pathSegments = url.pathname.split('/').filter(Boolean);
    const id = pathSegments[pathSegments.length - 1];

    if (!id) {
      return createValidationErrorResponse(
        'id',
        'ID parameter is required'
      );
    }

    let response: Response;
    
    if (request.method === 'PUT') {
      response = await update<%= entity.pascalName %>(request, id);
    } else if (request.method === 'PATCH') {
      response = await patch<%= entity.pascalName %>(request, id);
    } else {
      return createErrorResponse('Method not allowed', 405);
    }
    
    // Add CORS headers to response
    const headers = new Headers(response.headers);
    Object.entries(corsHeaders).forEach(([key, value]) => {
      headers.set(key, value);
    });

    return new Response(response.body, {
      status: response.status,
      headers,
    });
  } catch (error) {
    console.error('Unhandled error in update <%= entity.camelName %>:', error);
    
    const errorResponse = createErrorResponse(
      'Internal server error',
      500
    );
    
    const headers = new Headers(errorResponse.headers);
    Object.entries(corsHeaders).forEach(([key, value]) => {
      headers.set(key, value);
    });

    return new Response(errorResponse.body, {
      status: errorResponse.status,
      headers,
    });
  }
}