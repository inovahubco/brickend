/**
 * Create <%= entity.name %> endpoint
 * Generated by Brickend Framework
 */

import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';
import { corsHeaders } from '../shared/utils/cors.ts';
import { validateAuth } from '../shared/utils/auth.ts';
import { <%= entity.pascalName %>CreateSchema } from '../shared/utils/validation.ts';
import {
  createSuccessResponse,
  createErrorResponse,
  createValidationErrorResponse,
  createCreatedResponse,
  handleSupabaseError,
  handleAsync,
} from '../shared/utils/response.ts';
import type { 
  <%= entity.pascalName %>, 
  <%= entity.pascalName %>Create,
  Database 
} from '../shared/interfaces/database.ts';

/**
 * Handle OPTIONS request for CORS
 */
function handleOptions(): Response {
  return new Response('ok', { headers: corsHeaders });
}

/**
 * Create a new <%= entity.camelName %>
 */
async function create<%= entity.pascalName %>(request: Request): Promise<Response> {
  const supabase = createClient<Database>(
    Deno.env.get('SUPABASE_URL') ?? '',
    Deno.env.get('SUPABASE_ANON_KEY') ?? '',
    {
      global: {
        headers: { Authorization: request.headers.get('Authorization')! },
      },
    }
  );

  // Validate authentication
  const authResult = await validateAuth(supabase);
  if (!authResult.success) {
    return createErrorResponse(authResult.error, 401);
  }

  const user = authResult.user;

  // Parse and validate request body
  let body;
  try {
    body = await request.json();
  } catch (error) {
    return createValidationErrorResponse(
      'body',
      'Invalid JSON in request body'
    );
  }

  // Validate input schema
  const validation = <%= entity.pascalName %>CreateSchema.safeParse(body);
  if (!validation.success) {
    const firstError = validation.error.errors[0];
    return createValidationErrorResponse(
      firstError.path.join('.'),
      firstError.message,
      validation.error.errors
    );
  }

  const data = validation.data;

  // Add audit fields
  const <%= entity.camelName %>Data: <%= entity.pascalName %>Create = {
    ...data,
    <% if (entity.hasAuditFields) { %>
    created_by: user.id,
    updated_by: user.id,
    <% } %>
  };

  // Insert into database
  return handleAsync(async () => {
    const { data: created<%= entity.pascalName %>, error } = await supabase
      .from('<%= entity.tableName %>')
      .insert(<%= entity.camelName %>Data)
      .select()
      .single();

    if (error) {
      return handleSupabaseError(error);
    }

    if (!created<%= entity.pascalName %>) {
      return createErrorResponse('Failed to create <%= entity.camelName %>', 500);
    }

    return createCreatedResponse(
      created<%= entity.pascalName %>,
      '<%= entity.pascalName %> created successfully'
    );
  }, 'Failed to create <%= entity.camelName %>');
}

/**
 * Main handler function
 */
export default async function handler(request: Request): Promise<Response> {
  // Handle CORS preflight
  if (request.method === 'OPTIONS') {
    return handleOptions();
  }

  // Only allow POST method
  if (request.method !== 'POST') {
    return createErrorResponse('Method not allowed', 405);
  }

  try {
    const response = await create<%= entity.pascalName %>(request);
    
    // Add CORS headers to response
    const headers = new Headers(response.headers);
    Object.entries(corsHeaders).forEach(([key, value]) => {
      headers.set(key, value);
    });

    return new Response(response.body, {
      status: response.status,
      headers,
    });
  } catch (error) {
    console.error('Unhandled error in create <%= entity.camelName %>:', error);
    
    const errorResponse = createErrorResponse(
      'Internal server error',
      500
    );
    
    const headers = new Headers(errorResponse.headers);
    Object.entries(corsHeaders).forEach(([key, value]) => {
      headers.set(key, value);
    });

    return new Response(errorResponse.body, {
      status: errorResponse.status,
      headers,
    });
  }
}