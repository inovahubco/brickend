{
  "name": "<%= project.name %>",
  "version": "<%= project.version || '1.0.0' %>",
  "description": "<%= project.description || `${project.displayName} - Generated by Brickend Framework` %>",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "supabase start && echo '\\n🚀 Development server ready!'",
    "build": "deno task build",
    "deploy": "supabase functions deploy --no-verify-jwt",
    "deploy:prod": "supabase functions deploy --project-ref $SUPABASE_PROJECT_REF",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase migration up",
    "db:generate-types": "supabase gen types typescript --local > supabase/shared/interfaces/database.ts",
    "db:generate-types:remote": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > supabase/shared/interfaces/database.ts",
    "db:seed": "supabase seed run",
    "test": "deno test --allow-all",
    "test:watch": "deno test --allow-all --watch",
    "lint": "deno lint",
    "format": "deno fmt",
    "type-check": "deno check supabase/functions/**/*.ts",
    "logs": "supabase functions logs",
    "logs:follow": "supabase functions logs --follow",
    "start": "supabase start",
    "stop": "supabase stop",
    "status": "supabase status",
    "link": "supabase link --project-ref $SUPABASE_PROJECT_REF",
    "setup": "npm run setup:env && npm run setup:supabase",
    "setup:env": "cp .env.example .env.local && echo '⚠️  Please configure your .env.local file'",
    "setup:supabase": "supabase init && supabase start",
    "clean": "supabase stop && rm -rf .supabase",
    <% if (project.features.auth) { %>
    "auth:users": "supabase auth list-users",
    "auth:create-user": "supabase auth create-user",
    <% } %>
    <% if (project.features.storage) { %>
    "storage:list": "supabase storage list",
    "storage:create-bucket": "supabase storage create-bucket",
    <% } %>
    <% project.entities.forEach(entity => { %>
    "generate:<%= entity.kebabName %>": "echo 'Generated <%= entity.pascalName %> CRUD endpoints'",
    <% }); %>
    "postinstall": "echo '✅ Dependencies installed successfully!'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "deno": ">=1.40.0"
  },
  "keywords": [
    "<%= project.name %>",
    "supabase",
    "edge-functions",
    "api",
    "typescript",
    "brickend",
    <% project.entities.forEach((entity, index) => { %>
    "<%= entity.kebabName %>"<%= index < project.entities.length - 1 ? ',' : '' %>
    <% }); %>
  ],
  "author": {
    "name": "<%= project.author.name || 'Generated by Brickend' %>",
    "email": "<%= project.author.email || '' %>",
    "url": "<%= project.author.url || '' %>"
  },
  "license": "<%= project.license || 'MIT' %>",
  "repository": {
    "type": "git",
    "url": "<%= project.repository || '' %>"
  },
  "bugs": {
    "url": "<%= project.repository ? `${project.repository}/issues` : '' %>"
  },
  "homepage": "<%= project.homepage || project.repository || '' %>",
  "config": {
    "supabase": {
      "projectId": "${SUPABASE_PROJECT_ID}",
      "projectRef": "${SUPABASE_PROJECT_REF}",
      "apiUrl": "${SUPABASE_URL}",
      "anonKey": "${SUPABASE_ANON_KEY}",
      "serviceRoleKey": "${SUPABASE_SERVICE_ROLE_KEY}"
    },
    "deployment": {
      "platform": "vercel",
      "region": "<%= project.deployment?.region || 'auto' %>",
      "environment": "<%= project.deployment?.environment || 'production' %>"
    }
  },
  "brickend": {
    "version": "<%= brickend.version %>",
    "template": "service/supabase",
    "generatedAt": "<%= new Date().toISOString() %>",
    "entities": [
      <% project.entities.forEach((entity, index) => { %>
      {
        "name": "<%= entity.name %>",
        "tableName": "<%= entity.tableName %>",
        "pascalName": "<%= entity.pascalName %>",
        "camelName": "<%= entity.camelName %>",
        "kebabName": "<%= entity.kebabName %>",
        "pluralName": "<%= entity.pluralName %>",
        "endpoints": {
          "create": "POST /api/<%= entity.kebabName %>",
          "read": "GET /api/<%= entity.kebabName %>",
          "readById": "GET /api/<%= entity.kebabName %>/:id",
          "update": "PUT /api/<%= entity.kebabName %>/:id",
          "patch": "PATCH /api/<%= entity.kebabName %>/:id",
          "delete": "DELETE /api/<%= entity.kebabName %>/:id"<% if (entity.hasSoftDelete) { %>,
          "restore": "PATCH /api/<%= entity.kebabName %>/:id?action=restore"<% } %>
        },
        "features": {
          "auth": <%= entity.requiresAuth || true %>,
          "validation": true,
          "pagination": true,
          "search": <%= entity.searchableFields ? true : false %>,
          "softDelete": <%= entity.hasSoftDelete || false %>,
          "ownership": <%= entity.hasOwnership || false %>,
          "audit": <%= entity.hasAuditFields || true %>
        }
      }<%= index < project.entities.length - 1 ? ',' : '' %>
      <% }); %>
    ],
    "features": {
      "auth": <%= project.features.auth || true %>,
      "storage": <%= project.features.storage || false %>,
      "realtime": <%= project.features.realtime || false %>,
      "cors": true,
      "validation": true,
      "errorHandling": true,
      "logging": true,
      "typescript": true
    },
    "deployment": {
      "platform": "<%= project.deployment?.platform || 'vercel' %>",
      "functions": [
        <% project.entities.forEach((entity, index) => { %>
        "api/<%= entity.kebabName %>"<%= index < project.entities.length - 1 ? ',' : '' %>
        <% }); %>
      ]
    }
  },
  "supabase": {
    "functions": {
      <% project.entities.forEach((entity, index) => { %>
      "<%= entity.kebabName %>": {
        "path": "./supabase/functions/<%= entity.kebabName %>",
        "methods": ["GET", "POST", "PUT", "PATCH", "DELETE"],
        "auth": <%= entity.requiresAuth !== false %>,
        "cors": true
      }<%= index < project.entities.length - 1 ? ',' : '' %>
      <% }); %>
    }
  },
  "volta": {
    "node": "20.10.0"
  },
  "packageManager": "npm@10.2.0"
}