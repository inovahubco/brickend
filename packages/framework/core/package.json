{
  "name": "@brickend/core",
  "version": "0.0.1",
  "description": "Brickend core template engine and framework functionality",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "check-types": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "brickend",
    "framework",
    "template-engine",
    "code-generation",
    "typescript"
  ],
  "author": "",
  "dependencies": {
    "ejs": "^3.1.10",
    "zod": "^3.23.8",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "prettier": "^3.5.3"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.18",
    "eslint": "^9.27.0",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
