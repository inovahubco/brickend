{
  "name": "@brickend/core",
  "version": "0.0.1",
  "description": "Brickend core functionality with Fastify integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:manual": "bun run build && node dist/test.js",
    "start": "node dist/index.js"
  },
  "keywords": [
    "brickend",
    "framework",
    "fastify",
    "typescript",
    "api",
    "backend",
    "plugins"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "fastify": "^5.3.3",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.18",
    "@fastify/type-provider-typebox": "^5.1.0",
    "eslint": "^9.27.0",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@brickend/validation": "*",
    "@brickend/logger": "*",
    "@brickend/error-handler": "*"
  },
  "peerDependenciesMeta": {
    "@brickend/validation": {
      "optional": true
    },
    "@brickend/logger": {
      "optional": true
    },
    "@brickend/error-handler": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
